# ═══════════════════════════════════════════════════════════════════
#  GreenHat 🧢  Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your keys (never commit .env!)
# ═══════════════════════════════════════════════════════════════════

# ─── Deployer ────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# ─── Explorer API Keys (for --verify) ────────────────────────────
BASE_SCAN_API_KEY=
BSC_SCAN_API_KEY=

# ─── Mainnet RPCs ────────────────────────────────────────────────
MAINNET_RPC_URL=
BASE_RPC_URL=
BNB_RPC_URL=

# ─── Testnet RPCs ────────────────────────────────────────────────
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
