# ═══════════════════════════════════════════════════════════════════
#  GreenHat 🧢  Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your keys (never commit .env!)
# ═══════════════════════════════════════════════════════════════════

# ─── Codecov ─────────────────────────────────────────────────────
CODECOV_TOKEN=

# ─── Deployer ────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ─── Explorer API Keys (for forge script --verify) ───────────────
ETHERSCAN_API_KEY=
BSC_SCAN_API_KEY=
BASE_SCAN_API_KEY=
POLYGON_SCAN_API_KEY=
OPTIMISM_SCAN_API_KEY=
ARBITRUM_SCAN_API_KEY=

# ─── DEX Pair (optional: set after deploy) ───────────────────────
# DEPLOY_DEX_PAIR=0x...

# ─── Mainnet RPCs ────────────────────────────────────────────────
MAINNET_RPC_URL=
BASE_RPC_URL=
BNB_RPC_URL=
POLYGON_RPC_URL=

# ─── Testnet RPCs ────────────────────────────────────────────────
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
