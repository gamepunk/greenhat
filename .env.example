# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your keys (never commit .env!)
# ═══════════════════════════════════════════════════════════════════

# ─── Codecov (for CI coverage upload — keep in sync with GitHub Secrets) ──
CODECOV_TOKEN=0ea21778-88e6-4537-8d41-a74fa6ee160d

# ─── Deployer ────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# ─── Explorer API Keys (for --verify) ────────────────────────────
BASE_SCAN_API_KEY=
BSC_SCAN_API_KEY=

# ─── Mainnet RPCs ────────────────────────────────────────────────
MAINNET_RPC_URL=
BASE_RPC_URL=
BNB_RPC_URL=

# ─── Testnet RPCs ────────────────────────────────────────────────
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
