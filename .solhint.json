{
  "extends": "solhint:recommended",
  "plugins": [],
  "rules": {
    "compiler-version": ["error", "^0.8.20"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "no-console": "off",
    "not-rely-on-time": "off",
    "quotes": ["warn", "double"],
    "const-name-snakecase": "warn",
    "contract-name-camelcase": "warn",
    "event-name-camelcase": "warn",
    "func-name-mixedcase": "warn",
    "func-param-name-mixedcase": "warn",
    "modifier-name-mixedcase": "warn",
    "private-vars-leading-underscore": "warn",
    "var-name-mixedcase": "warn",
    "imports-on-top": "warn",
    "ordering": "warn",
    "visibility-modifier": "warn",
    "no-empty-blocks": "warn",
    "no-unused-vars": "warn",
    "payable-fallback": "off",
    "reason-string": ["warn", { "maxLength": 64 }],
    "constructor-syntax": "warn",
    "comprehensive-interface": "off",
    "separate-by-one-line-in-contract": "warn",
    "two-lines-top-level-separator": "warn",
    "max-line-length": ["warn", 120],
    "code-complexity": ["warn", 8],
    "function-max-lines": ["warn", 80],
    "no-inline-assembly": "off"
  }
}
